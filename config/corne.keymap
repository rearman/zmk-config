#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/bt.h>
#include "42-keys.h"

&mt {
	tapping-term-ms = <150>;
};

/ {
	macros {
		thorn: thorn {
			compatible = "zmk,behavior-macro";
			#binding-cells = <0>;
			wait-ms = <30>;
			tap-ms = <40>;
			bindings = <&kp PAUSE_BREAK &kp T &kp H>;
		};
		eng: eng {
			compatible = "zmk,behavior-macro";
			#binding-cells = <0>;
			wait-ms = <30>;
			tap-ms = <40>;
			bindings = <&kp PAUSE_BREAK &kp N &kp G>;
		};
	};

	combos {
		compatible = "zmk,combos";
		combo_cut {
			bindings = <&kp LC(X)>;
			key-positions = <LT2 LT3>; // , .
			timeout-ms = <50>;
		};
		combo_copy {
			bindings = <&kp LC(C)>;
			key-positions = <LT2 LT3 LT4>; // , . p
			timeout-ms = <50>;
		};
		combo_paste {
			bindings = <&kp LC(V)>;
			key-positions = <LT2 LT4>; // , p
			timeout-ms = <50>;
		};
		combo_thorn {
			bindings = <&thorn>;
			key-positions = <RM1 RM2>; // h t
			timeout-ms = <50>;
		};
		combo_eng {
			bindings = <&eng>;
			key-positions = <RT1 RM3>; // g n
			timeout-ms = <50>;
		};
	};

	behaviors {
		lhm: left_homerow_mods {
			compatible = "zmk,behavior-hold-tap";
			#binding-cells = <2>;
			flavor = "balanced";
			tapping-term-ms = <290>;
			quick-tap-ms = <175>;
			require-prior-idle-ms = <150>;
			hold-trigger-key-positions = <RIGHT_SIDE>;
			hold-trigger-on-release;
			bindings = <&kp>, <&kp>;
		};
		rhm: right_homerow_mods {
			compatible = "zmk,behavior-hold-tap";
			#binding-cells = <2>;
			flavor = "balanced";
			tapping-term-ms = <290>;
			quick-tap-ms = <175>;
			require-prior-idle-ms = <150>;
			hold-trigger-key-positions = <LEFT_SIDE>;
			hold-trigger-on-release;
			bindings = <&kp>, <&kp>;
		};
		lhs: left_homerow_shift {
			compatible = "zmk,behavior-hold-tap";
			#binding-cells = <2>;
			flavor = "balanced";
			tapping-term-ms = <290>;
			quick-tap-ms = <175>;
			require-prior-idle-ms = <100>;
			hold-trigger-key-positions = <RIGHT_SIDE>;
			hold-trigger-on-release;
			bindings = <&kp>, <&kp>;
		};
		rhs: right_homerow_shift {
			compatible = "zmk,behavior-hold-tap";
			#binding-cells = <2>;
			flavor = "balanced";
			tapping-term-ms = <290>;
			quick-tap-ms = <175>;
			require-prior-idle-ms = <100>;
			hold-trigger-key-positions = <LEFT_SIDE>;
			hold-trigger-on-release;
			bindings = <&kp>, <&kp>;
		};
		skq: sticky_key_quick_release {
			compatible = "zmk,behavior-sticky-key";
			#binding-cells = <1>;
			bindings = <&kp>;
			release-after-ms = <1000>;
			quick-release;
		};
	};

	keymap {
		compatible = "zmk,keymap";
		default_layer {
			display-name = "BASE";
			/*
			 *  0	TAB	'	,	.	P	Y	F	G	C	R	L	/
			 *  1	=	A	O	E	U	I	D	H	T	N	S	-
			 *  2	`	;	Q	J	K	X	B	M	W	V	Z	\
			 *  3				DEL	ESC	BSP	SPC	CAP	RET
			 */
			bindings = <
				&kp TAB		&kp  SQT	&kp COMMA	&kp DOT		&kp P		&kp Y		&kp F		&kp G		&kp C		&kp R		&kp  L		&kp FSLH
				&kp EQUAL	&lhm LGUI A	&lhm LALT O	&lhm LCTL E	&lhs LSFT U	&kp I		&kp D		&rhs RSFT H	&rhm RCTL T	&rhm RALT N	&rhm RGUI S	&kp MINUS
				&kp GRAVE	&kp SEMI	&kp Q		&kp J		&kp K		&kp X		&kp B		&kp M		&kp W		&kp V		&kp Z		&kp BSLH
										&kp DEL		&lt 2 ESC	&lt 1 BSPC	&lt 1 SPACE	&lt 2 CAPS	&kp RET
			>;
		};
		num_layer {
			display-name = "NUM";
			/*
			 *	ESC	XXX	[	]	XXX	XXX	XXX	7	8	9	XXX	___
			 *	___	XXX	(	)	XXX	XXX	XXX	4	5	6	.	___
			 *	___	XXX	{	}	XXX	XXX	XXX	1	2	3	XXX	___
			 *				___	___	___	___	0	___
			 */
			bindings = <
				&trans	&none	&kp LBKT	&kp RBKT	&none	&none	&none	&kp N7		&kp N8		&kp N9		&none		&trans
				&trans	&trans	&lhm LALT LPAR	&lhm LCTL RPAR	&trans	&none	&none	&rhs RSFT N4	&rhm RCTL N5	&rhm RALT N6	&rhm RGUI DOT	&trans
				&trans	&none	&kp LBRC	&kp RBRC	&none	&none	&none	&kp N1		&kp N2		&kp N3		&none		&trans
								&trans		&trans	&trans	&trans	&kp N0		&trans
			>;
		};
		nav_layer {
			display-name = "NAV";
			/*
			 *	ESC	F1	F2	F3	F4	XXX	XXX	HOM	UP	PUP	CAP	___
			 *	___	F5	F6	F7	F8	INS	XXX	LFT	APP	RHT	DEL	___
			 *	___	F9	F10	F11	F12	XXX	XXX	END	DN	PDN	PSC	___
			 *				___	___	___	___	___	___
			 */
			bindings = <
				&trans	&kp F1		&kp F2		&kp F3		&kp F4		&none	&none	&kp HOME	&kp UP		&kp PG_UP	&kp CAPS	&trans
				&trans	&lhm LGUI F5	&lhm LALT F6	&lhm LCTL F7	&lhs LSFT F8	&kp INS	&none	&rhs RSFT LEFT	&rhm RCTL K_APP	&rhm RALT RIGHT	&rhm RGUI DEL	&trans
				&trans	&kp F9		&kp F10		&kp F11		&kp F12		&none	&none	&kp END		&kp DOWN	&kp PG_DN	&kp PSCRN	&trans
									&trans		&trans		&trans	&trans	&trans		&trans
			>;
		};
	};
};
