#define CUSTOM_MOD_TAP(NAME, MOD, CUSTOM) \
	cmt_##NAME: custom_mod_tap_##NAME { \
		compatible = "zmk,behavior-hold-tap"; \
		#binding-cells = <2>; \
		tapping_term_ms = <175>; \
		quick_tap_ms = <150>; \
		flavor = "hold-preferred"; \
		bindings = <&kp MOD>, <CUSTOM>; \
	};

CUSTOM_MOD_TAP(ls_tilde, LSFT, &re_tilde)
